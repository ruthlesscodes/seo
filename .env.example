# ============================================
# SEO Agent Service - Environment Configuration
# ============================================

# Server
PORT=4200
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL on Railway/Supabase/Neon)
DATABASE_URL="postgresql://user:password@host:5432/seo_agent?schema=public"

# Redis (for job queues - Railway Redis or Upstash)
REDIS_URL="redis://default:password@host:6379"

# Firecrawl API
FIRECRAWL_API_KEY="fc-YOUR_API_KEY"
FIRECRAWL_BASE_URL="https://api.firecrawl.dev/v2"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-YOUR_API_KEY"

# Stripe (for SaaS billing)
STRIPE_SECRET_KEY="sk_test_YOUR_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_SECRET"
STRIPE_PRICE_STARTER="price_xxx"
STRIPE_PRICE_GROWTH="price_xxx"
STRIPE_PRICE_SCALE="price_xxx"

# Slack Notifications (optional)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx/xxx/xxx"

# Email (for reports)
SMTP_HOST="smtp.mailgun.org"
SMTP_USER=""
SMTP_PASS=""

# ============================================
# SaaS Multi-tenant Settings
# ============================================
# Set to 'true' when running as standalone SaaS
MULTI_TENANT=false
MAX_KEYWORDS_PER_TENANT=100
MAX_COMPETITORS_PER_TENANT=10
