# ============================================
# SEO Agent API — Environment Variables
# ============================================

# Server
PORT=4200
NODE_ENV=development
API_BASE_URL=http://localhost:4200

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/seo_agent

# Redis (for BullMQ job queue + rate limiting + caching)
REDIS_URL=redis://localhost:6379

# Firecrawl — the scraping/crawling engine
# Get key: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-YOUR-KEY
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
FIRECRAWL_TIMEOUT_MS=90000

# Anthropic Claude — the AI analysis engine
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY
CLAUDE_MODEL=claude-sonnet-4-20250514

# Stripe — billing
STRIPE_SECRET_KEY=sk_test_YOUR-KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR-SECRET
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_GROWTH_PRICE_ID=price_xxx
STRIPE_SCALE_PRICE_ID=price_xxx

# JWT — API key signing
JWT_SECRET=generate-a-64-char-random-string-here

# Internal — Plu org auto-registration
PLU_ORG_NAME=Plu
PLU_ORG_DOMAIN=getplu.com

# Webhooks — outbound delivery
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# Optional: PostHog analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ============================================
# Weekly Digest Email (score, trend, priorities, monitor count)
# SMTP — works with any provider (Gmail, SendGrid, Mailgun, etc.)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SEO Agent <digest@yourdomain.com>

# Dashboard URL for digest links (e.g. https://app.getplu.com)
DASHBOARD_URL=

# ============================================
# DeerFlow — Multi-Agent Orchestration
# On Railway: leave DEERFLOW_URL blank until DeerFlow is deployed
# ============================================
DEERFLOW_URL=
DEERFLOW_GATEWAY_URL=

# ============================================
# Google OAuth — Search Console integration
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Google Search Console API
# On Railway: GOOGLE_REDIRECT_URI=https://your-api.up.railway.app/api/auth/gsc/callback
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4200/api/auth/gsc/callback

# ============================================
# Google PageSpeed Insights API — Lighthouse scores
# No Chrome/Chromium needed. Same scores, zero server overhead.
# Free: 25,000 req/day — https://developers.google.com/speed/docs/insights/v5/get-started
# ============================================
GOOGLE_PAGESPEED_API_KEY=
