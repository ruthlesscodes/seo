// ============================================
// SEO Agent - Database Schema
// Supports both single-tenant (for Plu) and
// multi-tenant (for SaaS product) modes
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Multi-tenant: Organization / Account
// ============================================
model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  domain          String   // Their primary domain to track
  stripeCustomerId String? @unique
  plan            Plan     @default(STARTER)
  status          OrgStatus @default(ACTIVE)
  
  // Limits based on plan
  maxKeywords     Int      @default(50)
  maxCompetitors  Int      @default(5)
  maxBlogsPerWeek Int      @default(3)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  users           User[]
  competitors     Competitor[]
  keywords        Keyword[]
  scrapeRuns      ScrapeRun[]
  blogDrafts      BlogDraft[]
  rankSnapshots   RankSnapshot[]
  
  @@index([slug])
  @@index([stripeCustomerId])
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  role            UserRole @default(MEMBER)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  
  createdAt       DateTime @default(now())
  
  @@index([organizationId])
}

// ============================================
// Competitors to Track
// ============================================
model Competitor {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  
  name            String
  domain          String
  blogPath        String   @default("/blog")
  isActive        Boolean  @default(true)
  
  // Last crawl data
  lastCrawledAt   DateTime?
  pagesFound      Int      @default(0)
  avgWordCount    Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  insights        CompetitorInsight[]
  
  @@unique([organizationId, domain])
  @@index([organizationId])
}

model CompetitorInsight {
  id              String   @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id])
  
  url             String
  title           String
  wordCount       Int
  headings        Json     // { h1s: [], h2s: [] }
  topics          String[]
  
  discoveredAt    DateTime @default(now())
  
  @@index([competitorId])
}

// ============================================
// Keywords & Tracking
// ============================================
model Keyword {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  
  keyword         String
  segment         String   @default("core")
  priority        Int      @default(2) // 1 = high, 2 = medium, 3 = low
  isActive        Boolean  @default(true)
  
  // Latest ranking data
  currentPosition Int?     // null = not ranking
  bestPosition    Int?
  opportunity     Opportunity @default(HIGH)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  rankings        RankSnapshot[]
  
  @@unique([organizationId, keyword])
  @@index([organizationId])
  @@index([segment])
}

model RankSnapshot {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  keywordId       String
  keyword         Keyword  @relation(fields: [keywordId], references: [id])
  
  position        Int?     // null = not found
  url             String?  // Which of our URLs ranked
  topResults      Json     // Top 10 results snapshot
  competitorPositions Json // { "wise.com": 3, "chime.com": 7 }
  
  snapshotDate    DateTime @default(now())
  
  @@index([keywordId, snapshotDate])
  @@index([organizationId, snapshotDate])
}

// ============================================
// Scrape Runs & Jobs
// ============================================
model ScrapeRun {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  
  type            RunType
  status          RunStatus @default(PENDING)
  
  // Results
  keywordsScraped Int      @default(0)
  competitorsCrawled Int   @default(0)
  contentGapsFound Int     @default(0)
  creditsUsed     Int      @default(0)
  
  // Claude analysis
  analysis        Json?    // The weekly brief
  
  startedAt       DateTime?
  completedAt     DateTime?
  error           String?
  
  createdAt       DateTime @default(now())
  
  @@index([organizationId, createdAt])
}

// ============================================
// Blog Drafts
// ============================================
model BlogDraft {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  
  title           String
  targetKeyword   String
  segment         String
  content         String   @db.Text
  wordCount       Int
  
  status          DraftStatus @default(DRAFT)
  seoScore        Int?     // 0-100
  
  // Metadata
  metaTitle       String?
  metaDescription String?
  slug            String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime?
  
  @@index([organizationId, status])
}

// ============================================
// Enums
// ============================================
enum Plan {
  STARTER     // $49/mo - 50 keywords, 3 competitors
  GROWTH      // $149/mo - 200 keywords, 10 competitors
  SCALE       // $499/mo - 1000 keywords, 25 competitors
  ENTERPRISE  // Custom
}

enum OrgStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum Opportunity {
  HIGH
  MEDIUM
  LOW
}

enum RunType {
  KEYWORD_SCRAPE
  COMPETITOR_CRAWL
  RANK_TRACK
  FULL_PIPELINE
  BLOG_GENERATION
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DraftStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}
