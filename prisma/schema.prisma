generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT: Organizations + Users
// ============================================

model Organization {
  id              String   @id @default(cuid())
  name            String
  domain          String
  plan            Plan     @default(FREE)
  stripeCustomerId String? @unique
  stripeSubId     String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  apiKeys         ApiKey[]
  users           User[]
  keywords        Keyword[]
  competitors     Competitor[]
  rankSnapshots   RankSnapshot[]
  blogDrafts      BlogDraft[]
  scrapeRuns      ScrapeRun[]
  monitoredUrls   MonitoredUrl[]
  auditRuns         AuditRun[]
  geoReports        GeoReport[]
  usageLogs         UsageLog[]
  webhookConfigs    WebhookConfig[]
  lighthouseReports LighthouseReport[]
  gscToken          OrgGSCToken?
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?  // bcrypt/scrypt hash for login
  role            UserRole @default(MEMBER)
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([orgId])
}

model ApiKey {
  id              String   @id @default(cuid())
  key             String   @unique
  name            String   @default("Default")
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([key])
  @@index([orgId])
}

// ============================================
// USAGE TRACKING + BILLING
// ============================================

model UsageLog {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  operation       String        // e.g. "keyword.search", "blog.generate"
  credits         Int
  endpoint        String        // e.g. "/api/keywords/search"
  metadata        Json?         // request details for audit
  createdAt       DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, operation])
}

// ============================================
// KEYWORDS
// ============================================

model Keyword {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keyword         String
  segment         String   @default("general")
  intent          KeywordIntent?
  difficulty      String?       // easy, medium, hard
  lastPosition    Int?
  lastCheckedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rankSnapshots   RankSnapshot[]

  @@unique([orgId, keyword])
  @@index([orgId, segment])
}

// ============================================
// RANKINGS
// ============================================

model RankSnapshot {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keywordId       String
  keyword         Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  position        Int?          // null = not ranking
  url             String?       // URL that's ranking
  region          String   @default("US")
  serpFeatures    Json?         // { featuredSnippet: bool, aiOverview: bool, paa: bool, ... }
  topResults      Json?         // top 5 SERP results snapshot
  checkedAt       DateTime @default(now())

  @@index([orgId, keywordId, checkedAt])
  @@index([keywordId, region, checkedAt])
}

// ============================================
// COMPETITORS
// ============================================

model Competitor {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  domain          String
  blogPath        String   @default("/blog")
  lastCrawledAt   DateTime?
  pageCount       Int?
  createdAt       DateTime @default(now())

  insights        CompetitorInsight[]

  @@unique([orgId, domain])
}

model CompetitorInsight {
  id              String   @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  insightType     String        // "content_gap", "pricing_change", "new_page", "ranking_shift"
  data            Json
  createdAt       DateTime @default(now())

  @@index([competitorId, insightType])
}

// ============================================
// CONTENT
// ============================================

model BlogDraft {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title           String
  targetKeyword   String
  content         String        @db.Text
  metaDescription String?
  wordCount       Int?
  status          ContentStatus @default(DRAFT)
  segment         String   @default("general")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, targetKeyword])
}

// ============================================
// MONITORING — Change Tracking
// ============================================

model MonitoredUrl {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  url             String
  label           String?       // "competitor pricing", "our blog post", etc.
  checkFrequency  CheckFrequency @default(DAILY)
  isActive        Boolean  @default(true)
  lastCheckedAt   DateTime?
  lastChangeAt    DateTime?
  createdAt       DateTime @default(now())

  changeEvents    ChangeEvent[]

  @@unique([orgId, url])
  @@index([orgId, isActive])
}

model ChangeEvent {
  id              String   @id @default(cuid())
  monitoredUrlId  String
  monitoredUrl    MonitoredUrl @relation(fields: [monitoredUrlId], references: [id], onDelete: Cascade)
  changeStatus    String        // "new", "changed", "unchanged", "removed"
  changeType      String?       // "content", "pricing", "structure", "metadata"
  diff            String?  @db.Text  // git-diff output
  structuredDiff  Json?         // JSON diff for pricing/features
  previousHash    String?
  currentHash     String?
  detectedAt      DateTime @default(now())

  @@index([monitoredUrlId, detectedAt])
}

// ============================================
// TECHNICAL SEO AUDITS
// ============================================

model AuditRun {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  domain          String
  status          JobStatus @default(PENDING)
  totalPages      Int?
  issuesFound     Int?
  summary         Json?         // { critical: N, warnings: N, info: N }
  startedAt       DateTime @default(now())
  completedAt     DateTime?

  auditPages      AuditPage[]

  @@index([orgId, startedAt])
}

model AuditPage {
  id              String   @id @default(cuid())
  auditRunId      String
  auditRun        AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  url             String
  statusCode      Int?
  metaTitle       String?
  metaDescription String?
  h1              String?
  h1Count         Int?
  wordCount       Int?
  hasCanonical    Boolean?
  canonicalUrl    String?
  hasSchemaOrg    Boolean?
  schemaTypes     Json?         // ["Article", "FAQPage", ...]
  internalLinks   Int?
  externalLinks   Int?
  images          Int?
  imagesNoAlt     Int?
  issues          Json?         // [{ type: "missing_meta", severity: "critical", ... }]
  checkedAt       DateTime @default(now())

  @@index([auditRunId])
}

// ============================================
// GEO / AEO
// ============================================

model GeoReport {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reportType      GeoReportType
  domain          String
  score           Int?          // 0-100 readability/citation score
  data            Json          // full report data
  recommendations Json?
  createdAt       DateTime @default(now())

  @@index([orgId, reportType])
}

// ============================================
// ASYNC JOBS
// ============================================

model ScrapeRun {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobType         String        // "pipeline", "audit", "monitor_batch"
  status          JobStatus @default(PENDING)
  config          Json?
  result          Json?
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([orgId, status])
}

// ============================================
// WEBHOOKS
// ============================================

model WebhookConfig {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  url             String
  events          Json          // ["pipeline.completed", "monitor.changed", "ranking.dropped"]
  secret          String?       // HMAC signing secret
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  deliveries      WebhookDelivery[]

  @@unique([orgId, url])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookConfigId String
  webhookConfig   WebhookConfig @relation(fields: [webhookConfigId], references: [id])
  event           String
  payload         Json
  statusCode      Int?
  response        String?  @db.Text
  attempts        Int      @default(0)
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([webhookConfigId, createdAt])
}

// ============================================
// ENUMS
// ============================================

enum Plan {
  FREE
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum KeywordIntent {
  INFORMATIONAL
  TRANSACTIONAL
  NAVIGATIONAL
  COMMERCIAL
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CheckFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum GeoReportType {
  READABILITY
  BRAND_MONITOR
  LLMSTXT
  CITATION_OPTIMIZATION
}

// ============================================
// LIGHTHOUSE + GSC
// ============================================

model LighthouseReport {
  id                   String   @id @default(cuid())
  orgId                String
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  url                  String
  performanceScore     Int?
  seoScore             Int?
  accessibilityScore   Int?
  bestPracticesScore   Int?
  lcpMs                Int?
  clsScore             Float?
  fcpMs                Int?
  ttfbMs               Int?
  tbtMs                Int?
  rawData              Json?
  createdAt            DateTime @default(now())

  @@index([orgId, url, createdAt])
}

model OrgGSCToken {
  id           String   @id @default(cuid())
  orgId        String   @unique
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  siteUrl      String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiryDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
